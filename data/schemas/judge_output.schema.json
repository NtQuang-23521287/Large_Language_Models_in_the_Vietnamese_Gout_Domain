{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JudgeOutput",
  "type": "object",
  "required": [
    "run_id",
    "question_id",
    "model_name",
    "judge_model"
  ],
  "properties": {
    "run_id": { "type": ["string", "null"] },
    "question_id": { "type": ["string", "null"] },
    "conversation_id": { "type": ["string", "null"] },
    "turn_id": { "type": ["string", "integer", "null"] },
    "scenario": { "type": ["string", "null"] },
    "dataset_label": { "type": ["string", "null"] },
    "question_type": { "type": ["string", "null"] },
    "risk_level": { "type": ["string", "integer", "null"] },
    "model_name": { "type": ["string", "null"] },
    "judge_model": { "type": "string" },
    "judge_output": {
      "type": "object",
      "properties": {
        "faithfulness": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "reason": { "type": "string" }
          }
        },
        "completeness": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "reason": { "type": "string" }
          }
        },
        "relevance": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "reason": { "type": "string" }
          }
        },
        "context_recall": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "reason": { "type": "string" }
          }
        },
        "patient_utility": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "reason": { "type": "string" }
          }
        },
        "hallucination_level": {
          "type": "object",
          "properties": {
            "level": { "type": "integer", "minimum": 0, "maximum": 3 },
            "reason": { "type": "string" }
          }
        },
        "omission_risk": {
          "type": "object",
          "properties": {
            "level": { "type": "integer", "minimum": 0, "maximum": 3 },
            "reason": { "type": "string" }
          }
        },
        "safety_risk": {
          "type": "object",
          "properties": {
            "level": { "type": "integer", "minimum": 0, "maximum": 3 },
            "reason": { "type": "string" }
          }
        },
        "refusal_appropriateness": {
          "type": "object",
          "properties": {
            "is_applicable": { "type": "boolean" },
            "score": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
            "reason": { "type": "string" }
          }
        },
        "citation_correctness": {
          "type": "object",
          "properties": {
            "score": { "type": ["number", "null"] },
            "reason": { "type": "string" }
          }
        },
        "overall_comment": { "type": "string" }
      },
      "additionalProperties": true
    },
    "error": { "type": "string" }
  },
  "additionalProperties": true
}
