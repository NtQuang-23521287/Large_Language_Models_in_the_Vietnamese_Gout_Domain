{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artifact",
  "type": "object",
  "required": [
    "run_id",
    "question_id",
    "question",
    "prompt",
    "answer",
    "meta"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "question_id": { "type": "string" },
    "conversation_id": { "type": ["string", "null"] },
    "turn_id": { "type": ["string", "integer", "null"] },
    "scenario": { "type": ["string", "null"] },
    "dataset_label": { "type": ["string", "null"] },
    "question": { "type": "string" },
    "question_type": { "type": ["string", "null"] },
    "risk_level": { "type": ["string", "integer", "null"] },
    "ground_truth": { "type": "string" },
    "required_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "forbidden_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "is_safety_trap": { "type": "boolean" },
    "evaluation_focus": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conversation_history": {
      "type": "array",
      "items": { "type": "object" }
    },
    "contexts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "retrieved_chunks": {
      "type": "array",
      "items": { "type": "object" }
    },
    "prompt": { "type": "string" },
    "answer": { "type": "string" },
    "meta": { "type": "object" },
    "generation_config": { "type": "object" }
  },
  "additionalProperties": true
}
